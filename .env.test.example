# Test environment — points to local Supabase instance
# Copy this file to .env.test and fill in the values from: npm run db:start && npx supabase status

SUPABASE_URL=http://localhost:54321
SUPABASE_KEY=<paste "anon key" from supabase status>
SUPABASE_SERVICE_ROLE_KEY=<paste "service_role key" from supabase status>
