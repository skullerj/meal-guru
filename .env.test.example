# Test environment — points to local Supabase instance
# Copy this file to .env.test and fill in the values from: npm run db:start && npx supabase status

SUPABASE_URL=http://localhost:54321
SUPABASE_PUB_KEY=<paste "Publishable" key from supabase status>
SUPABASE_KEY=<paste "Secret" key from supabase status>
