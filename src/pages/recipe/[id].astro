---
import CookingView from "../../components/recipe/CookingView";
import Layout from "../../layouts/Layout.astro";
import { getRecipe } from "../../lib/database";

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/recipes");
}

const recipe = await getRecipe(id);

if (!recipe) {
  return Astro.redirect("/recipes");
}

const referer = Astro.request.headers.get("referer");
let backUrl = "/recipes";
if (referer) {
  try {
    const refPath = new URL(referer).pathname;
    if (refPath.startsWith("/shop/")) {
      backUrl = refPath;
    }
  } catch {}
}
---

<Layout title={recipe.name}>
  <CookingView recipe={recipe} backUrl={backUrl} client:load />
</Layout>
