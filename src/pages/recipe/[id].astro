---
export const prerender = false;

import CookingView from "../../components/recipe/CookingView";
import Layout from "../../layouts/Layout.astro";
import { getRecipe } from "../../lib/database";
import { createSupabaseServerClient } from "../../lib/supabase";

const supabase = createSupabaseServerClient({
  headers: Astro.request.headers,
  cookies: Astro.cookies,
});

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/recipes");
}

const recipe = await getRecipe(supabase, id);

if (!recipe) {
  return Astro.redirect("/recipes");
}

---

<Layout title={recipe.name}>
  <CookingView recipe={recipe} client:load />
</Layout>
