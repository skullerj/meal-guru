---
import IngredientList from "../components/ingredients/IngredientList";
import Layout from "../layouts/Layout.astro";
import { getIngredients } from "../lib/database";
import { createSupabaseServerClient } from "../lib/supabase";

const supabase = createSupabaseServerClient({
  headers: Astro.request.headers,
  cookies: Astro.cookies,
});

const ingredients = await getIngredients(supabase);
---

<Layout title="Ingredients">
  <main class="min-h-screen bg-background">
    <div class="max-w-lg w-full mx-auto px-6 py-8">
      <header class="mb-8">
        <h1 class="text-3xl font-bold text-foreground font-heading">Ingredients</h1>
        <p class="text-muted-foreground mt-1">
          Master ingredient library — {ingredients.length} ingredient{ingredients.length !== 1 ? "s" : ""}
        </p>
      </header>

      <IngredientList client:load ingredients={ingredients} />
    </div>
  </main>
</Layout>
