---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Recipes">
  <main class="min-h-screen bg-background">
    <div class="max-w-3xl mx-auto px-4 py-12">
      <header class="mb-8 flex items-center justify-between">
        <div>
          <a
            href="/"
            class="text-sm text-muted-foreground hover:text-foreground mb-2 inline-flex items-center gap-1"
          >
            ← Home
          </a>
          <h1 class="text-2xl font-bold text-foreground">Recipes</h1>
        </div>
      </header>

      <p class="text-muted-foreground">Recipe management coming soon.</p>
    </div>
  </main>
</Layout>
