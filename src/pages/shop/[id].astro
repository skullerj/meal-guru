---
import { aggregateIngredients } from "../../components/meal-planner/utils/mealPlannerUtils";
import ShopPage from "../../components/shop/ShopPage";
import Layout from "../../layouts/Layout.astro";
import { getShopIngredients, getShopWithRecipes } from "../../lib/database";

const { id } = Astro.params;
if (!id) return Astro.redirect("/");

const shop = await getShopWithRecipes(id);
if (!shop) return Astro.redirect("/");

const shopIngredients = await getShopIngredients(id);

const groups = aggregateIngredients(
  shop.recipes,
  shop.recipes.map((r) => r.id)
);
---

<Layout title="Shopping List">
  <main class="min-h-screen bg-background">
    <ShopPage
      client:load
      shopId={id}
      recipes={shop.recipes}
      groups={groups}
      shopIngredients={shopIngredients}
      initialStatus={shop.status ?? "shopping"}
    />
  </main>
</Layout>
