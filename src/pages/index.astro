---
import ShopNowButton from "../components/ShopNowButton";
import Layout from "../layouts/Layout.astro";
import { getRecentRecipeIds, getRecipes } from "../lib/database";

const recipes = await getRecipes();
const recipeIds = recipes.map((r) => r.id);
const recentIds = await getRecentRecipeIds();
---

<Layout title="Home">
  <main class="min-h-screen bg-background flex items-center justify-center">
    <div class="max-w-lg w-full mx-auto px-6 py-16 text-center">
      <h1 class="text-4xl font-bold text-foreground mb-3">Meal Guru</h1>
      <p class="text-lg text-muted-foreground mb-10">What are you cooking this week?</p>

      <div class="flex flex-col items-center gap-5">
        <ShopNowButton client:load recipeIds={recipeIds} excludeIds={recentIds} />
        <a href="/pick" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
          Pick recipes manually →
        </a>
      </div>
    </div>
  </main>
</Layout>
