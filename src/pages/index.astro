---
import MealPlanner from "../components/meal-planner/MealPlanner";
import Layout from "../layouts/Layout.astro";
import { getRecipes } from "../lib/database";

const recipes = await getRecipes();
---

<Layout title="Home">
  <main class="min-h-screen bg-background">
    <div class="max-w-5xl mx-auto px-4 py-12">
      <header class="mb-10">
        <h1 class="text-3xl font-bold text-foreground">Meal Guru</h1>
        <p class="text-muted-foreground mt-1">What are you cooking this week?</p>
      </header>

      <MealPlanner client:load recipes={recipes} />
    </div>
  </main>
</Layout>
