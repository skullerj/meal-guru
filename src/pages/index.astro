---
import MealPlanner from "../components/meal-planner/MealPlanner";
import Layout from "../layouts/Layout.astro";
import { getAllIngredients, getRecipes } from "../lib/database";

const [recipes, ingredients] = await Promise.all([
  getRecipes(),
  getAllIngredients(),
]);
---

<Layout>
    <MealPlanner recipes={recipes} ingredients={ingredients} client:load />
</Layout>
