---
interface Props {
  title?: string;
}

const { title = "Meal Guru" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#CF6A43" />
    <title>{title} — Meal Guru</title>
  </head>
  <body>
    <nav class="border-b border-border bg-background">
      <div class="max-w-5xl mx-auto px-4 py-3 flex items-center gap-6">
        <a href="/" class="text-sm font-semibold text-foreground hover:text-primary transition-colors">Meal Guru</a>
        <a href="/pick" class="text-sm text-muted-foreground hover:text-foreground transition-colors">Plan</a>
        <a href="/recipes" class="text-sm text-muted-foreground hover:text-foreground transition-colors">Recipes</a>
        <a href="/ingredients" class="text-sm text-muted-foreground hover:text-foreground transition-colors">Ingredients</a>
      </div>
    </nav>
    <slot />
  </body>
</html>

<style is:global>
  @import "@fontsource-variable/geist";
</style>

<style is:global>
  @import "../styles/global.css";
</style>
