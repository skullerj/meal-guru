---
const currentPath = Astro.url.pathname;

const navItems = [
  { href: "/", label: "Meal Planner" },
  { href: "/add-recipe", label: "Add Recipe" },
  { href: "/ingredients", label: "Ingredients" },
  { href: "/shops", label: "Shops" },
];

const isActive = (href: string) => {
  if (href === "/") {
    return currentPath === "/";
  }
  return currentPath.startsWith(href);
};

const isLoggedIn = Astro.cookies.get("sb-access-token") !== undefined;
---

<nav class="bg-white border-b border-gray-200 shadow-sm">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <div class="flex items-center space-x-1">
        <a
          href="/"
          class="text-amber-500 hover:text-amber-400 text-xl font-bold mr-8"
        >
          Meal Guru
        </a>
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
                isActive(item.href)
                  ? "bg-blue-50 text-amber-500"
                  : "text-stone-600 hover:text-stone-900 hover:bg-stone-50"
              }`}
            >
              {item.label}
            </a>
          ))
        }
      </div>
      {
        isLoggedIn ? (
          <a
            href="/logout"
            class="px-4 py-2 rounded-lg text-sm font-medium text-stone-600 hover:text-stone-900 hover:bg-stone-50 transition-colors"
          >
            Logout
          </a>
        ) : null
      }
    </div>
  </div>
</nav>
